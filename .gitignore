# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Testing
.pytest_cache/
htmlcov/
.coverage

# Runtime workspace output (task files, archives — ignore contents, not the folder)
testSpace/
workspace/*
!workspace/AGENT_LOOP.md
workspace/archive/
output/
*.md.bak

# Private workflow definitions — only sample_workflow is public.
# All other workflows are local-only and will never be committed.
workflows/*
!workflows/sample_workflow
workflows/sample_workflow/*
!workflows/sample_workflow/v1
workflows/sample_workflow/v1/*
!workflows/sample_workflow/v1/*.json
!workflows/sample_workflow/v1/guidance.md

# IDE
.vscode/
.idea/

# Claude Code local settings
.claude/

# Node.js
frontend/node_modules/
frontend/.next/
frontend/.tsbuildinfo
frontend/package-lock.json

# Local State
.carddealer_state.json

# Launch scripts (may contain credentials — never commit these)
run_orchestrator.ps1
run_orchestrator.sh
run_orchestrator.bat
*.local.ps1
*.local.sh

# User credentials config (copy from configure_user.sample.json)
configure_user.json

# Runtime logs (may contain URLs, tokens, or other ephemeral secrets)
nohup.out
*.log

# OS
.DS_Store
Thumbs.db
/README.md
/configure_user.json